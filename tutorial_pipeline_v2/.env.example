# ============================================
# LLM ENGINES (PRIORITY)
# ============================================
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=qwen2.5:14b
LOCAL_LLM_STRICT=0

GOOGLE_API_KEY=your_google_api_key_optional

LLM_ENGINE_PRIMARY=Groq
LLM_ENGINE_SECONDARY=Local (Ollama)
LLM_ENGINE_FALLBACK=Gemini (GRATIS)

# ============================================
# ACTIVE PUBLISHING PLATFORMS (NO MEDIUM)
# ============================================
DEVTO_API_KEY=your_devto_api_key

HASHNODE_API_KEY=your_hashnode_api_key
HASHNODE_PUBLICATION_ID=your_hashnode_publication_id

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=@your_channel

BLOGGER_ACCESS_TOKEN=your_blogger_access_token
BLOGGER_REFRESH_TOKEN=your_blogger_refresh_token
BLOGGER_BLOG_ID=your_blogger_blog_id
BLOGGER_CLIENT_ID=your_blogger_client_id
BLOGGER_CLIENT_SECRET=your_blogger_client_secret

# ============================================
# AUTONOMOUS CONFIG
# ============================================
AUTO_GENERATE_ENABLED=true
AUTO_GENERATE_PER_DAY=3
AUTO_PUBLISH_TIMES=09:00,14:00,20:00
TRENDS_UPDATE_HOUR=2
PIPELINE_TIMEZONE=America/Santiago
CRON_WINDOW_MINUTES=15
FORCE_ENGLISH=true
DEFAULT_LANGUAGE=en
DEFAULT_LENGTH=medium
PRIORITY_CATEGORIES=python,javascript,react,git,docker

# Growth funnel (used in article footer + Telegram CTA)
SPONSOR_CTA_ENABLED=true
BUSINESS_CONTACT_EMAIL=hello@autonomousworld.dev
SPONSORSHIP_PAGE_URL=https://autonomousworld.hashnode.dev/work-with-me
NEWSLETTER_URL=https://autonomousworld.hashnode.dev/newsletter
COMMUNITY_URL=https://t.me/autonomousworlddev
SPONSOR_CTA_TEXT=Want weekly practical tutorials and collaboration opportunities?

# Sponsor hunter and outreach bot
GITHUB_TOKEN=
SPONSOR_SEARCH_KEYWORDS=ai,automation,developer tools,devops,testing,api,saas
SPONSOR_HUNTER_MAX_LEADS=30
SPONSOR_MIN_SCORE=35
OUTREACH_SEND_ENABLED=false
OUTREACH_MAX_EMAILS_PER_RUN=10
OUTREACH_SENDER_NAME=Nico
OUTREACH_FROM_EMAIL=nico.ai.studio@gmail.com
OUTREACH_REPLY_TO=nico.ai.studio@gmail.com
OUTREACH_SITE_OR_PROFILE=https://autonomousworld.hashnode.dev
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# ============================================
# TRENDS + CACHE
# ============================================
TRENDS_CACHE_DURATION=6
TREND_SOURCES=devto,hashnode,github,reddit

ENABLE_CONTENT_CACHE=true
CACHE_DURATION=24
LOG_LEVEL=INFO
REQUEST_TIMEOUT_S=30
MAX_RETRIES=3
